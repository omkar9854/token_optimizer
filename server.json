{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.omkar9854/token_optimizer",
  "description": "Reversible context compression for AI agents: cut token usage up to 94%, originals retrievable",
  "repository": {
    "url": "https://github.com/omkar9854/token_optimizer",
    "source": "github"
  },
  "version": "0.1.0",
